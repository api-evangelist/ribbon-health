        "_excl_insurance_ids": {
          "type": "array",
          "description": "List of insurance uuids to exclude. Exclude locations that accept a given insurance(s).",
          "example": [
            "e527f6e3-fe42-4932-bf34-d81f1c1fd652"
          ],
          "items": {
            "type": "string",
            "format": "uuid"
          }
        },
        "insurance_carrier_name": {
